# Valhalla API Configuration
# Using public Valhalla API (https://valhalla1.openstreetmap.de)
VALHALLA_API_URL=https://valhalla1.openstreetmap.de

# Open-Elevation API for elevation data
# https://api.open-elevation.com/api/v1/lookup
OPEN_ELEVATION_API_URL=https://api.open-elevation.com/api/v1/lookup

# Elevation sampling: Distance in meters between elevation points
# 50m = ~20 points per km (for 500km route = ~10,000 points)
ELEVATION_SAMPLE_DISTANCE_M=50

# Corporate proxy SSL (if needed):
# Option 1: NODE_EXTRA_CA_CERTS=/Users/Philipp.Arndt/root-ca.crt
# Option 2: NODE_TLS_REJECT_UNAUTHORIZED=0 (dev only)
