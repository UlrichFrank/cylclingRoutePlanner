# Valhalla API Configuration
VALHALLA_API_URL=https://valhalla1.openstreetmap.de

# For corporate proxy environments with self-signed certificates
# Option 1: Set NODE_EXTRA_CA_CERTS to your company's root CA certificate
# NODE_EXTRA_CA_CERTS=/Users/Philipp.Arndt/root-ca.crt

# Option 2 (if NODE_EXTRA_CA_CERTS is not available): Disable TLS verification
# WARNING: Only for development! Not for production!
NODE_TLS_REJECT_UNAUTHORIZED=0
