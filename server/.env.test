# Test Environment Configuration
# Uses Mock Valhalla for deterministic, fast testing

# Mock Valhalla (for tests)
VALHALLA_API_URL=http://localhost:8003

# Open-Elevation API (but will fail in tests - mock returns 404)
OPEN_ELEVATION_API_URL=https://api.open-elevation.com/api/v1/lookup

# Elevation sampling distance
ELEVATION_SAMPLE_DISTANCE_M=50

# Server
PORT=3001
NODE_ENV=test
