# Valhalla Routing API
VITE_VALHALLA_API_URL=https://valhalla1.openstreetmap.de

# Backend API for CORS proxying
VITE_BACKEND_API_URL=http://localhost:3001/api

# Optional: Fallback to Public API (e.g., for production)
# VITE_VALHALLA_PUBLIC_API=https://valhalla.api.example.com
# VITE_VALHALLA_API_KEY=your-api-key-here

# Map & Geocoding
VITE_NOMINATIM_ENDPOINT=https://nominatim.openstreetmap.org

# Debug
VITE_DEBUG_LOGGING=false
